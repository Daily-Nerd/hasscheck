[0.000, "o", "\u001b[1mFix suggestions\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mhacs.file.parseable\u001b[0m\r\n"]
[0.000, "o", "    Add a repository-level hacs.json file, even if it starts as an empty JSON object.\r\n"]
[0.000, "o", "  \u001b[1mbrand.icon.exists\u001b[0m\r\n"]
[0.001, "o", "    Add custom_components/\u001b[1m<\u001b[0m\u001b[1;95mdomain\u001b[0m\u001b[1m>\u001b[0m\u001b[35m/brand/\u001b[0m\u001b[95micon.png.\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mmanifest.domain.matches_directory\u001b[0m\r\n"]
[0.000, "o", "    Rename the integration directory or update manifest.domain so both use the same stable domain.\r\n"]
[0.000, "o", "  \u001b[1mmanifest.iot_class.valid\u001b[0m\r\n"]
[0.000, "o", "    Set iot_class to one of: assumed_state, calculated, cloud_polling, cloud_push, local_polling, local_push.\r\n"]
[0.000, "o", "  \u001b[1mmanifest.integration_type.exists\u001b[0m\r\n"]
[0.000, "o", "    Add an integration_type field to manifest.json.\r\n"]
[0.000, "o", "  \u001b[1mmanifest.integration_type.valid\u001b[0m\r\n"]
[0.000, "o", "    Add an integration_type field to manifest.json.\r\n"]
[0.000, "o", "  \u001b[1mmanifest.requirements.no_git_or_url_specs\u001b[0m\r\n"]
[0.000, "o", "    Replace git/URL specs with published PyPI package names.\r\n"]
[0.000, "o", "  \u001b[1mconfig_flow.user_step.exists\u001b[0m\r\n"]
[0.001, "o", "    Add async_step_user to your ConfigFlow class in config_flow.py.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/config_entries_config_flow_handler/#defining-the-flow\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mconfig_flow.reauth_step.exists\u001b[0m\r\n"]
[0.000, "o", "    Add async_step_reauth \u001b[1m(\u001b[0mand optionally async_step_reauth_confirm\u001b[1m)\u001b[0m to your ConfigFlow class.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/config_entries_config_flow_handler/#reauthentication\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mconfig_flow.reconfigure_step.exists\u001b[0m\r\n"]
[0.000, "o", "    Add async_step_reconfigure to your ConfigFlow class.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/config_entries_config_flow_handler/#reconfigure\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mconfig_flow.unique_id.set\u001b[0m\r\n"]
[0.000, "o", "    Call \u001b[1;35mself.async_set_unique_id\u001b[0m\u001b[1m(\u001b[0m\u001b[1m<\u001b[0m\u001b[1;95mdevice-identifier\u001b[0m\u001b[1m>\u001b[0m\u001b[1m)\u001b[0m before creating the entry.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/config_entries_config_flow_handler/#unique-ids\u001b[0m\r\n"]
[0.001, "o", "  \u001b[1mconfig_flow.connection_test\u001b[0m\r\n"]
[0.000, "o", "    Add a connection test \u001b[1m(\u001b[0me.g. await \u001b[1;35mvalidate_input\u001b[0m\u001b[1m(\u001b[0mhass, data\u001b[1m)\u001b[0m\u001b[1m)\u001b[0m inside async_step_user.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/config_entries_config_flow_handler/#defining-the-flow\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mdiagnostics.redaction.used\u001b[0m\r\n"]
[0.000, "o", "    Use async_redact_data or a local redaction helper before returning entry data.\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/core/integration/diagnostics/\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mrepairs.file.exists\u001b[0m\r\n"]
[0.000, "o", "    Add repairs.py when the integration has user-fixable repair scenarios.\r\n"]
[0.000, "o", "    Run: hasscheck scaffold repairs\r\n"]
[0.000, "o", "    Docs: \u001b[4;94mhttps://developers.home-assistant.io/docs/core/integration/repairs/\u001b[0m\r\n"]
[0.000, "o", "  \u001b[1mdocs.installation.exists\u001b[0m\r\n"]
[0.001, "o", "    Add an Installation section to README.md covering HACS and/or manual installation steps.\r\n"]
[0.000, "o", "  \u001b[1mdocs.configuration.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a Configuration section to README.md describing available options and setup steps.\r\n"]
[0.000, "o", "  \u001b[1mdocs.troubleshooting.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a Troubleshooting or FAQ section to README.md with known issues and debug steps.\r\n"]
[0.000, "o", "  \u001b[1mdocs.removal.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a Removal or Uninstall section to README.md with steps to cleanly remove the integration.\r\n"]
[0.000, "o", "  \u001b[1mdocs.privacy.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a Privacy or Data section to README.md describing what data the integration collects or sends.\r\n"]
[0.001, "o", "  \u001b[1mrepo.license.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a repository license file such as LICENSE.\r\n"]
[0.000, "o", "  \u001b[1mtests.folder.exists\u001b[0m\r\n"]
[0.000, "o", "    Add a tests/ directory with pytest-based integration tests.\r\n"]
[0.000, "o", "  \u001b[1mci.github_actions.exists\u001b[0m\r\n"]
