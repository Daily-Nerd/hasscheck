# Generated by hasscheck — review before committing.
# Sibling: github_action.yml.tmpl (default; non-publish variant).
# Keep both templates in sync when bumping versions or adding steps.
# This variant grants id-token: write and sets emit-publish: 'true'.
name: CI

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read
  id-token: write

jobs:
  tests:
    name: Python $${{ matrix.python-version }}
    runs-on: ubuntu-latest

    strategy:
      fail-fast: false
      matrix:
        python-version:
          - "3.12"
          - "3.13"

    steps:
      - name: Check out repository
        uses: actions/checkout@v6

      - name: Set up uv
        uses: astral-sh/setup-uv@v8.1.0
        with:
          enable-cache: true
          cache-dependency-glob: uv.lock

      - name: Install dependencies
        run: uv sync --locked --dev

      - name: Run tests
        run: uv run pytest -q

  hasscheck:
    name: HassCheck
    runs-on: ubuntu-latest
    needs: tests
    permissions:
      contents: read
      id-token: write
    steps:
      - name: Check out repository
        uses: actions/checkout@v6

      - name: Run HassCheck (publish)
        uses: Daily-Nerd/hasscheck@main
        with:
          path: '.'
          emit-publish: 'true'
